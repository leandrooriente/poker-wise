{
  "name": "poker-wise",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "npm run cf:build && opennextjs-cloudflare preview",
    "deploy:dev": "npm run cf:build && opennextjs-cloudflare deploy",
    "deploy:production": "npm run cf:build && opennextjs-cloudflare deploy --env production",
    "cf:typegen": "tsx scripts/generate-cloudflare-types.ts",
    "cf:secrets": "tsx scripts/sync-cloudflare-secrets.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:d1": "vitest --config vitest.d1.config.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "e2e": "playwright test",
    "e2e:local": "playwright test --project=chromium --workers=1 --max-failures=1",
    "e2e:ui": "playwright test --ui",
    "preview:wait": "tsx scripts/wait-for-preview-ready.ts",
    "e2e:install": "playwright install",
    "db:generate": "drizzle-kit generate",
    "db:export:postgres": "tsx scripts/export-postgres-to-d1.ts",
    "db:verify:d1": "tsx scripts/verify-d1-migration.ts",
    "db:writes:freeze": "tsx scripts/set-postgres-write-freeze.ts freeze",
    "db:writes:unfreeze": "tsx scripts/set-postgres-write-freeze.ts unfreeze",
    "db:migrate": "npm run db:migrate:local",
    "db:migrate:local": "wrangler d1 migrations apply poker-wise-dev --local",
    "db:migrate:dev": "wrangler d1 migrations apply poker-wise-dev --remote",
    "db:migrate:production": "wrangler d1 migrations apply poker-wise-prod --remote --env production",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:init": "tsx scripts/db-init.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "admin:create": "tsx scripts/create-admin.ts"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "iron-session": "^8.0.4",
    "next": "16.2.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@cloudflare/workers-types": "5.20260710.1",
    "@opennextjs/cloudflare": "1.20.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "4.1.10",
    "dotenv": "^17.3.1",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "pg": "8.22.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.33.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
